{
  "name": "f2tools",
  "displayName": "F2Tools",
  "description": "",
  "publisher": "TF2P",
  "version": "2.0.26",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheForty2Project/F2Tools/"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "F2Tools.Reports.Execute",
        "title": "F2Tools.Reports.Execute: Execute query"
      },
      {
        "command": "F2Tools.Reports.WriteBack",
        "title": "F2Tools.Reports.WriteBack: Write back from output file"
      },
      {
        "command": "f2tools.specifyStandupReport",
        "title": "Specify Standup Report"
      },
      {
        "command": "f2tools.taskSelection",
        "title": "Start timer on Task"
      },
      {
        "command": "f2tools.pauseResumeTimer",
        "title": "Pause/Resume Task"
      },
      {
        "command": "f2tools.stopTimer",
        "title": "Stop timer on Task"
      },
      {
        "command": "f2tools.generateWorkLogs",
        "title": "Generate WorkLogs from SR"
      },
      {
        "command": "f2tools.extractF2YamlSummaryLink",
        "title": "Extract F2Yaml Summary Link"
      },
      {
        "command": "f2tools.extractF2YamlIdLink",
        "title": "Extract F2Yaml Id Link"
      },
      {
        "command": "f2tools.followF2yamlLink",
        "title": "Follow the F2Yaml Link"
      },
      {
        "command": "f2tools.generateCSV",
        "title": "Generate CSV Line from Task"
      }
    ],
    "configuration": {
      "title": "F2Tools",
      "properties": {
        "F2Tools.logLevel": {
          "type": "string",
          "default": "Info",
          "enum": [
            "None",
            "Error",
            "Warning",
            "Info",
            "Debug"
          ],
          "enumDescriptions": [
            "Disable logging",
            "Show only errors",
            "Show warnings and errors",
            "Show informational messages, warnings and errors",
            "Show all messages"
          ],
          "description": "Controls the extension log level."
        },
        "F2Tools.userName": {
          "type": "string",
          "default": "YourUserName",
          "description": "Your username"
        },
        "F2Tools.pathSeparator": {
          "type": "string",
          "description": "The separator to use in the extracted YAML path.",
          "default": "."
        },
        "F2Tools.csvFields": {
          "type": "array",
          "description": "Fields of the csv generated.",
          "items": {
            "type": "string"
          },
          "default": [
            "TaskStatus",
            "By",
            "Estimation",
            "RemTime",
            "IdLink",
            "DependsOn"
          ]
        },
        "F2Tools.workspacePath": {
          "type": "string",
          "description": "If you are using the extension without workspace enter the workspace path here",
          "default": ""
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.98.0",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.19.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "yaml": "^2.7.1"
  }
}